generator client {
  provider = "prisma-client-js"
}

// The url below is unused at runtime (both the app's PrismaClient in src/lib/db.ts and
// the CLI via prisma.config.ts connect through the libSQL driver adapter, reading
// TURSO_DATABASE_URL/TURSO_AUTH_TOKEN directly) — Prisma's schema parser just requires
// a syntactically valid file: url here for the sqlite provider.
datasource db {
  provider = "sqlite"
  url      = "file:local-placeholder.db"
}

model Loan {
  id             String    @id @default(cuid())
  borrowerName   String
  contact        String
  amountBorrowed Float
  dateBorrowed   String
  dueDate        String
  notes          String    @default("")
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  payments       Payment[]
}

model Payment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount Float
  date   String
  note   String @default("")
}

model Settings {
  id             String  @id @default("global")
  lateFeeEnabled Boolean @default(true)
}
